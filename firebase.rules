rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }

    match /users/{uid} {
      allow read: if isSignedIn() && (uid == request.auth.uid || role() in ['central','state']);
      allow write: if isSignedIn() && uid == request.auth.uid;
    }

    match /budgets/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (role() in ['central','state']);
    }

    match /fund_flows/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (role() in ['central','state','ia']);
      allow update, delete: if isSignedIn() && (role() in ['central','state']);
    }

    match /utilization_certificates/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (role() in ['ia']);
      allow update: if isSignedIn() && (role() in ['central','state']);
      allow delete: if isSignedIn() && (role() in ['central']);
    }

    match /implementing_agencies/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (role() in ['central','state']);
    }

    match /executing_agencies/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (role() in ['central','state','ia']);
      allow delete: if isSignedIn() && (role() in ['central','state']);
    }

    match /projects/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (role() in ['central','state','ia']);
    }

    match /alerts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (role() in ['central','state','ia']);
      allow update: if isSignedIn() && (role() in ['central','state','monitor']);
      allow delete: if isSignedIn() && (role() in ['central']);
    }

    match /geo_tracking/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (role() in ['ea','ia','monitor','state','central']);
    }
  }
}
